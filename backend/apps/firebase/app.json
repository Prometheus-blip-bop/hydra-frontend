{
  "name": "FIREBASE",
  "display_name": "Firebase",
  "logo": "https://logo.clearbit.com/firebase.google.com",
  "provider": "Google",
  "version": "1.0.0",
  "description": "App development platform that helps you build and grow apps and games users love.",
  "security_schemes": {
    "oauth2": {
      "location": "header",
      "name": "Authorization",
      "prefix": "Bearer",
      "client_id": "{{ GOOGLE_CLIENT_ID }}",
      "client_secret": "{{ GOOGLE_CLIENT_SECRET }}",
      "scope": "https://www.googleapis.com/auth/firebase https://www.googleapis.com/auth/datastore",
      "authorize_url": "https://accounts.google.com/o/oauth2/v2/auth",
      "access_token_url": "https://oauth2.googleapis.com/token",
      "refresh_token_url": "https://oauth2.googleapis.com/token"
    }
  },
  "default_security_credentials_by_scheme": {},
  "categories": ["Developer Tools", "Database"],
  "visibility": "public",
  "active": true
}
